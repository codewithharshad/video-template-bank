# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth — set to true when ready to enable sign-in, credits, and billing
NEXT_PUBLIC_AUTH_ENABLED=false

# Clerk (https://vercel.com/marketplace/clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Neon Postgres (https://vercel.com/marketplace/neon)
DATABASE_URL=

# Payments — which provider is active: "dodo" (global) | "razorpay" (India, later)
PAYMENT_PROVIDER=dodo

# Dodo Payments — global Merchant of Record (https://app.dodopayments.com)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Optional: where Dodo redirects after checkout (defaults to /account?checkout=success)
DODO_PAYMENTS_RETURN_URL=
# Product IDs from the Dodo dashboard for each paid plan
DODO_CREATOR_PRODUCT_ID=
DODO_PRO_PRODUCT_ID=

# Stripe (legacy / optional — not used while PAYMENT_PROVIDER=dodo)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREATOR_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Vercel Blob (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=

# Admin access — comma-separated Clerk user IDs
ADMIN_USER_IDS=

# Export — local ffmpeg dev, or remote render worker on Railway/Fly
ENABLE_SERVER_EXPORT=true
RENDER_WORKER_URL=
RENDER_WORKER_SECRET=
# Optional on render worker: REMOTION_CONCURRENCY=1 (default 1 on Railway)
