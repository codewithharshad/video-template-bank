{
  "name": "video-lib",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@video-lib/web",
    "dev:worker": "npm run dev --workspace=@video-lib/render-worker",
    "build": "npm run build --workspace=@video-lib/web",
    "lint": "npm run lint --workspace=@video-lib/web",
    "db:push": "npm run db:push --workspace=@video-lib/database"
  },
  "engines": {
    "node": ">=20"
  }
}
